                        local ListSize = DropdownList.AbsoluteSize.Y
                        if MousePos < ListPos or MousePos > ListPos + ListSize then
                            DropdownList.Visible = false
                            DropdownList.Size = UDim2.new(0.3, -10, 0, 0)
                        end
                    end
                end)
            end
            
            function SectionItems:NewSlider(SliderText, SliderDesc, Min, Max, Callback)
