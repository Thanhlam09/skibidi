-- SỬA LỖI: Tạo các folder cần thiết nếu chưa có
local RS = game:GetService("ReplicatedStorage")

local requiredFolders = {"Util", "Common", "Remotes", "Assets", "FX"}
for _, folderName in pairs(requiredFolders) do
    if not RS:FindFirstChild(folderName) then
        local newFolder = Instance.new("Folder")
        newFolder.Name = folderName
        newFolder.Parent = RS
    end
end

-- Tạo Modules.Net nếu chưa có
if not RS:FindFirstChild("Modules") then
    local modules = Instance.new("Folder")
    modules.Name = "Modules"
    modules.Parent = RS
end

local modules = RS:FindFirstChild("Modules")
if modules and not modules:FindFirstChild("Net") then
    local net = Instance.new("Folder")
    net.Name = "Net"
    net.Parent = modules
end

-- Code gốc đã được sửa (dùng FindFirstChild thay vì truy cập trực tiếp)
